{
    "name": "Upcoming booking list",
    "description": "This view displays the list of bookings: the first starting on top.",
    "access": {
        "groups": ["booking.default.user"]
    },
    "order": "date_from",
    "sort": "asc",
    "controller": "sale_booking_collect-upcoming-month",
    "domain": ["center_office_id", "in", "user.center_offices_ids"],
    "header": {
        "selection": {
            "default": false,
            "actions" : [
                {
                    "id": "archive_bulk",
                    "label": "Archiver",
                    "icon": "archive",
                    "controller": "sale_booking_bulk-archive",
                    "confirm": true
                },
                {
                    "id": "update_booking_bulk",
                    "label": "Mettre à jour le status",
                    "icon": "update",
                    "controller": "sale_booking_bulk-update-status",
                    "confirm": true
                }
            ]
        },
        "actions": {
            "ACTION.CREATE" : [
                {
                    "view": "form.create",
                    "description": "overload form to use for booking creation"
                }
            ]
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "name",
                "label": "reference",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "display_name",
                "width": "35%",
                "sortable": true,
                "widget": {
                    "wrap": true
                }
            },
            {
                "type": "field",
                "value": "created",
                "width": "15%",
                "sortable": true,
                "widget": {
                    "usage": "datetime/short"
                }
            },
            {
                "type": "field",
                "label": "From",
                "value": "date_from",
                "width": "15%",
                "readonly": true,
                "sortable": true
            },
            {
                "type": "field",
                "label": "To",
                "value": "date_to",
                "width": "15%",
                "sortable": true,
                "readonly": true
            },
            {
                "type": "field",
                "value": "status",
                "width": "10%",
                "sortable": true,
                "readonly": true
            },
            {
                "type": "field",
                "value": "is_cancelled",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "alert",
                "width": "10%",
                "readonly": true,
                "sortable": true
            },
            {
                "type": "field",
                "label": "Customer",
                "value": "customer_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Type",
                "value": "type_id",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "wrap": true
                }
            },
            {
                "type": "field",
                "label": "Center",
                "value": "center_id",
                "width": "15%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Nb Pers",
                "value": "nb_pers",
                "width": "10%",
                "sortable": true,
                "readonly": true
            },
            {
                "type": "field",
                "label": "Price",
                "value": "price",
                "width": "10%",
                "sortable": true,
                "readonly": true
            },
            {
                "type": "field",
                "value": "paid_amount",
                "width": "10%",
                "sortable": true,
                "readonly": true
            },
            {
                "type": "field",
                "value": "payment_status",
                "width": "10%",
                "widget": {
                    "type": "string",
                    "usage": "icon",
                    "sortable": true,
                    "readonly": true
                }
            }
        ]
    }
}
