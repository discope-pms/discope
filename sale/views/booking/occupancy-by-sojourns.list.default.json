{
    "name": "Occupations planning",
    "description": "List of occupations of rooms and buildings between two dates.",
    "access": {
        "groups": ["booking.default.user"]
    },
    "actions": [
        {
            "id": "action.occupancy-csv",
            "label": "Occupations CSV",
            "description": "Download occupations CSV.",
            "controller": "lathus_sale_booking_consumption_occupancy-csv"
        }
    ],
    "header": {
        "actions": {
            "ACTION.CREATE": false
        },
        "advanced_search": {
            "open": true
        }
    },
    "group_by": [
        {
            "open": true,
            "field": "rental_unit_name",
            "operations": {
                "nb_pers": {
                    "operation": "SUM"
                },
                "nb_children": {
                    "operation": "SUM"
                },
                "nb_adults": {
                    "operation": "SUM"
                }
            }
        }
    ],
    "domain": [
        ["center_id", "in", "user.centers_ids"]
    ],
    "order": "date",
    "sort" : "asc",
    "controller": "sale_booking_occupancy-by-sojourns",
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "rental_unit_name",
                "width": "33%",
                "visible": false
            },
            {
                "type": "field",
                "value": "sojourn_date_from",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "sojourn_date_to",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "customer",
                "width": "33%"
            },
            {
                "type": "field",
                "value": "nb_pers",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "nb_children",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "nb_adults",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "age_ranges",
                "width": "15%"
            }
        ]
    }
}
