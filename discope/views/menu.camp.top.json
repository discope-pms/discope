{
    "name": "Camps menu",
    "access": {
        "groups": ["camp.default.user", "camp.default.administrator"]
    },
    "layout": {
        "items": [
            {
                "id": "item.planning_employees",
                "label": "Employees schedule",
                "description": "",
                "icon": "person_outline",
                "type": "entry",
                "route": "/planning/employees",
                "visible": [true, "=", "env.sale.features.booking.employee_planning"]
            },
            {
                "id": "item.waiting_followup_tasks",
                "label": "Waiting tasks",
                "description": "",
                "icon": "list_alt",
                "type": "entry",
                "context": {
                    "entity": "sale\\camp\\followup\\Task",
                    "view": "list.waiting",
                    "order": "id",
                    "sort": "desc",
                    "domain": [
                        ["entity", "=", "sale\\camp\\Enrollment"],
                        ["is_done", "=", false],
                        ["deadline_date", "<=", "date.this.day"]
                    ]
                }
            }
        ]
    }
}
