{
    "name": "Booking menu",
    "access": {
      "groups": ["booking.default.user"]
    },
    "layout": {
        "items": [
            {
                "id": "item.home",
                "label": "Home",
                "description": "",
                "icon": "home",
                "type": "entry",
                "route": "/"
            },
            {
                "id": "item.planning",
                "label": "Planning",
                "description": "",
                "icon": "person_outline",
                "type": "entry",
                "route": "/planning"
            },
            {
                "id": "item.planning_employees",
                "label": "Employees schedule",
                "description": "",
                "icon": "person_outline",
                "type": "entry",
                "route": "/planning/employees",
                "visible": [true, "=", "env.sale.features.booking.employee_planning"]
            },
            {
                "id": "item.bookings",
                "label": "Bookings",
                "description": "",
                "icon": "menu_book",
                "type": "entry",
                "route": "/bookings",
                "context": {
                    "entity": "sale\\booking\\Booking",
                    "view": "list.default",
                    "order": "id",
                    "sort": "desc"
                }
            },
            {
                "id": "item.waiting_followup_tasks",
                "label": "Waiting tasks",
                "description": "",
                "icon": "list_alt",
                "type": "entry",
                "context": {
                    "entity": "sale\\booking\\followup\\Task",
                    "view": "list.waiting",
                    "order": "id",
                    "sort": "desc",
                    "domain": [
                        ["entity", "=", "sale\\booking\\Booking"],
                        ["is_done", "=", false],
                        ["deadline_date", "<=", "date.this.day"]
                    ]
                },
                "visible": [true, "=", "env.sale.features.booking.tasks_table"]
            }
        ]
    }
}
